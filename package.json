{
  "name": "supabase-ssh-repo",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm --filter supabase-ssh run build",
    "dev": "pnpm --filter supabase-ssh run dev",
    "test": "pnpm --filter supabase-ssh run test",
    "start": "pnpm --filter supabase-ssh run start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ssh2"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}
