{
  "uid": "supabase-ssh-sessions-resources",
  "title": "Supabase SSH / Sessions & Resources",
  "description": "Session behavior, memory, event loop health",
  "tags": ["ssh", "sessions", "resources"],
  "timezone": "utc",
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "app",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(ssh_active_connections, app)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(ssh_active_connections{app=~\"$app\"}, instance)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "Session Behavior",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Session End Reasons",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (end_reason) (increase(ssh_session_duration_seconds_count{app=~\"$app\", instance=~\"$instance\"}[$__range]))",
          "legendFormat": "{{ end_reason }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Session Duration by Mode (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ssh_session_duration_seconds_bucket{app=~\"$app\", instance=~\"$instance\", mode=\"shell\"}[15m])) by (le))",
          "legendFormat": "shell p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ssh_session_duration_seconds_bucket{app=~\"$app\", instance=~\"$instance\", mode=\"shell\"}[15m])) by (le))",
          "legendFormat": "shell p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ssh_session_duration_seconds_bucket{app=~\"$app\", instance=~\"$instance\", mode=\"exec\"}[15m])) by (le))",
          "legendFormat": "exec p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ssh_session_duration_seconds_bucket{app=~\"$app\", instance=~\"$instance\", mode=\"exec\"}[15m])) by (le))",
          "legendFormat": "exec p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 3,
      "title": "Session Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(ssh_session_duration_seconds_bucket{app=~\"$app\", instance=~\"$instance\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{ le }}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Blues" }
      }
    },
    {
      "id": 101,
      "title": "Resource Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{app=~\"$app\", instance=~\"$instance\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{app=~\"$app\", instance=~\"$instance\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_external_memory_bytes{app=~\"$app\", instance=~\"$instance\"}",
          "legendFormat": "External (Buffers)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 5,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(nodejs_eventloop_lag_seconds_total{app=~\"$app\", instance=~\"$instance\"}[5m])",
          "legendFormat": "avg lag"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{app=~\"$app\", instance=~\"$instance\"}",
          "legendFormat": "p99 lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 6,
      "title": "Active Connections vs Limits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(ssh_active_connections{app=~\"$app\", instance=~\"$instance\"})",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Rejection Rate vs Connection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(ssh_sessions_total{app=~\"$app\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "connections/s"
        },
        {
          "expr": "sum(rate(ssh_connection_rejections_total{app=~\"$app\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "rejections/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "custom": { "fillOpacity": 10 } }
      }
    }
  ],
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "schemaVersion": 39
}
