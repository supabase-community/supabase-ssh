{
  "name": "supabase-ssh",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch --env-file=.env.local src/server.ts",
    "generate:host-key": "tsx scripts/generate-host-key.ts",
    "generate:host-key:local": "tsx scripts/generate-host-key.ts > ssh_host_key",
    "deploy:prod": "pnpm run --filter docs build:guides-markdown && fly deploy ../.. --config \"$(pwd)/fly.toml\" --app supabase-ssh",
    "deploy:staging": "pnpm run --filter docs build:guides-markdown && fly deploy ../.. --config \"$(pwd)/fly.toml\" --app supabase-ssh-staging",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "chalk": "^5.4.1",
    "hono": "^4.12.7",
    "just-bash": "^2.11.15",
    "prom-client": "^15.1.3",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.4",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
