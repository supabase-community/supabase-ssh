{
  "name": "supabase-ssh",
  "version": "0.1.2",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "setup:docs": "rm -rf docs && mkdir -p docs && curl -sL https://supabase.com/docs/docs.tar.gz | tar -xz -C docs",
    "dev": "[ -d docs ] || pnpm run setup:docs && touch .env.local && tsx watch --env-file=.env.local src/server.ts",
    "generate:host-key": "tsx scripts/generate-host-key.ts",
    "generate:host-key:local": "tsx scripts/generate-host-key.ts > ssh_host_key",
    "test": "vitest run",
    "load-test": "tsx load-test/cli.ts",
    "load-test:capture": "tsx --env-file=.env.local load-test/scripts/capture-session.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "chalk": "^5.4.1",
    "hono": "^4.12.12",
    "just-bash": "^2.11.15",
    "prom-client": "^15.1.3",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@types/node": "^22",
    "@types/ssh2": "^1.15.4",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
